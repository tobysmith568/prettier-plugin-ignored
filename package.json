{
  "name": "prettier-plugin-ignored",
  "version": "0.0.0",
  "description": "A Prettier plugin that adds an 'ignored' language, allowing you to ignore files without listing them in a .prettierignore file.",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "prettier": "@tobysmith568/prettier-config",
  "type": "module",
  "keywords": [
    "prettier",
    "prettier-plugin",
    "configuration",
    "format",
    "autoformat",
    "autoformatter",
    "ignore",
    "prettierignore"
  ],
  "author": {
    "name": "Toby Smith",
    "email": "contact@tobythe.dev",
    "url": "https://tobysmith.uk"
  },
  "homepage": "https://github.com/tobysmith568/prettier-plugin-ignored",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobysmith568/prettier-plugin-ignored.git"
  },
  "bugs": {
    "url": "https://github.com/tobysmith568/prettier-plugin-ignored/issues"
  },
  "license": "ISC",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest"
  },
  "dependencies": {
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "prettier": "3.x"
  },
  "devDependencies": {
    "@license-cop/permissive": "^1.9.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tobysmith568/eslint-config": "^2.7.1",
    "@tobysmith568/prettier-config": "^2.2.1",
    "license-cop": "^1.9.0",
    "rollup": "^4.59.0",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
